{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "ide-assistant",
        "--project", "${CLAUDE_PROJECT_DIR}"
      ],
      "env": {
        "SERENA_HOME": "${CLAUDE_PLUGIN_DATA}/serena"
      }
    },
    "basic-memory": {
      "command": "uvx",
      "args": ["basic-memory", "mcp"],
      "env": {
        "BASIC_MEMORY_HOME": "${CLAUDE_PLUGIN_DATA}/basic-memory/knowledge"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
