# cc-config.env — single parameterization file for the hook system.
#
# Install: copy this file to <your-project>/.claude/cc-config.env and adjust.
# Every hook sources hooks/lib/cc-config.sh, which loads this file when present
# and falls back to the defaults shown below otherwise.
#
# Plain KEY="value" shell syntax — this file is sourced by bash.

# ── Package manager ──────────────────────────────────────────────────────────
# The ALLOWED package manager: npm | pnpm | yarn.
# package-manager-guard denies the other two when they appear in command
# position of a Bash call.
CC_PKG_MANAGER="npm"

# ── Stop-hook validation ─────────────────────────────────────────────────────
# nx      — track touched Nx projects (via project.json lookup) and run
#           `npx nx build|lint <project>` for each on Stop.
# command — track touched project files and run CC_VALIDATE_CMD once on Stop
#           when anything was touched.
# off     — no touch tracking, no Stop validation.
CC_VALIDATE_MODE="off"

# Used only when CC_VALIDATE_MODE=command,
# e.g. "npm run lint && npm run typecheck"
CC_VALIDATE_CMD=""

# ── Migration safety ─────────────────────────────────────────────────────────
# on | off — blocks destructive TypeORM/SQL operations in Bash commands
# (migration:revert, schema:drop, DROP TABLE, TRUNCATE, unscoped DELETE) and
# asks for approval before Write/Edit of files under a migrations/ directory.
CC_MIGRATION_GUARD="off"

# ── Memory nudge ─────────────────────────────────────────────────────────────
# Regex matched against user prompts to detect service/module names that
# should trigger a "query long-term memory first" reminder,
# e.g. "[a-z-]*-svc". Empty disables the nudge entirely.
CC_MEMORY_NUDGE_REGEX=""

# ── Nav guard (Serena symbol-search redirect) ────────────────────────────────
# on | off — redirects bash grep/rg/ag/ack searches for code SYMBOLS to
# Serena MCP tools. Set to off if Serena is not installed.
CC_NAV_GUARD="on"

# Class-like name suffixes that classify a search pattern as a code symbol.
CC_NAV_GUARD_SUFFIXES="Service|Controller|Repository|Module|Entity|Dto|Port|Mapper|Guard|Interceptor|Producer|Consumer|Provider|Factory|Strategy|Decorator|Pipe|Filter|Exception|Middleware|Adapter|Client|Worker|Task|Job|Event"

# Leading camelCase verbs that classify a search pattern as a method symbol.
CC_NAV_GUARD_VERBS="find|get|create|update|delete|remove|set|has|is|prepare|build|make|to|from|validate|normalize|parse|resolve|extract|generate|handle|process|execute|register|add|apply|check|ensure|load|save|fetch|convert|map|transform|filter|sort|merge|split|format|emit|dispatch|enqueue|publish|subscribe|reset|init|bootstrap|compute"

# ── Path scopes ──────────────────────────────────────────────────────────────
# Project source-tree roots (pipe-separated, no trailing slash) used by
# read-guard to decide whether a bash file op targets project source.
CC_SOURCE_DIRS="apps|libs|tools|src|config"

# Dirs (pipe-separated, WITH trailing slash) where bash writes/copies/moves
# are hard-blocked by config-guard-bash (native Write/Edit must be used).
CC_PROTECTED_WRITE_DIRS="apps/|libs/"

# ── State home ───────────────────────────────────────────────────────────────
# Directory (relative to the project root) where hooks keep their state:
# denial-cap counters, memory buffers, session checkpoints, touched-file
# list, /feature flow-state. Add it to .gitignore.
CC_STATE_DIR=".cc_settings"
